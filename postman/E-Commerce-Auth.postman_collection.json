{
	"info": {
		"_postman_id": "b2a7c1e4-9f3d-4c6a-8e21-0f5d6a7b8c90",
		"name": "E-Commerce Laravel - Auth",
		"description": "Authentication endpoints (send OTP, verify OTP, register, login) for the E-Commerce Laravel API.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Send OTP",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{email}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/auth/send-otp",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"auth",
						"send-otp"
					]
				},
				"description": "Sends a 6-digit verification code to the given email address. Rate limited to 3 requests per minute."
			},
			"response": []
		},
		{
			"name": "Verify OTP",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{email}}\",\n    \"code\": \"{{otp_code}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/auth/verify-otp",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"auth",
						"verify-otp"
					]
				},
				"description": "Verifies the OTP code for the given email. Rate limited to 5 requests per minute."
			},
			"response": []
		},
		{
			"name": "Register",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"if (pm.response.code === 201) {",
							"    var json = pm.response.json();",
							"    if (json.token) {",
							"        pm.collectionVariables.set(\"auth_token\", json.token);",
							"    }",
							"}"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"{{name}}\",\n    \"email\": \"{{email}}\",\n    \"phone_number\": \"{{phone_number}}\",\n    \"password\": \"{{password}}\",\n    \"password_confirmation\": \"{{password}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/auth/register",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"auth",
						"register"
					]
				},
				"description": "Registers a new user. Requires the email to be verified first. Stores the returned token in the auth_token collection variable."
			},
			"response": []
		},
		{
			"name": "Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"if (pm.response.code === 200) {",
							"    var json = pm.response.json();",
							"    if (json.token) {",
							"        pm.collectionVariables.set(\"auth_token\", json.token);",
							"    }",
							"}"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{email}}\",\n    \"password\": \"{{password}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/auth/login",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"auth",
						"login"
					]
				},
				"description": "Logs in an existing user. Stores the returned token in the auth_token collection variable."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api",
			"type": "string"
		},
		{
			"key": "email",
			"value": "user@example.com",
			"type": "string"
		},
		{
			"key": "otp_code",
			"value": "123456",
			"type": "string"
		},
		{
			"key": "name",
			"value": "John Doe",
			"type": "string"
		},
		{
			"key": "phone_number",
			"value": "07712345678",
			"type": "string"
		},
		{
			"key": "password",
			"value": "password123",
			"type": "string"
		},
		{
			"key": "auth_token",
			"value": "",
			"type": "string"
		}
	]
}
